# ─── TxLINE (devnet) ─────────────────────────────────────────────────────────
TXLINE_API_BASE_URL=https://txline-dev.txodds.com/api
TXLINE_JWT_URL=https://txline-dev.txodds.com/auth/guest/start
# World Cup free tier
TXLINE_COMPETITION_ID=72
# Long-lived API token minted once via the free-tier subscribe+activate flow
# (scripts/txline-activate.ts). JWT is refreshed automatically.
TXLINE_API_TOKEN=

# ─── Solana (devnet) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# TxLINE txoracle program (devnet) — CPI target for validate_stat_v2
NEXT_PUBLIC_TXORACLE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_TOKEN_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG
# Our settlement program (filled after `anchor deploy`)
NEXT_PUBLIC_SETTLEMENT_PROGRAM_ID=
# Devnet USDC (or a test SPL mint) used for escrow
NEXT_PUBLIC_USDC_MINT=
# Backend service keypair (base58 or JSON array) that subscribed to the free
# tier + runs the settle keeper. NEVER commit the real value.
SOLANA_SERVICE_KEYPAIR=

# ─── Database (Neon / Vercel Postgres) ──────────────────────────────────────
DATABASE_URL=

# ─── AI (market drafting via 0G inference router) ───────────────────────────
ZEROG_API_KEY=
ZEROG_BASE_URL=https://router-api.0g.ai/v1
ZEROG_MODEL=deepseek-v4-pro

# ─── Privy (embedded Solana wallets, email login) ────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3010
# Optional: when set, /api/keeper requires `Authorization: Bearer $CRON_SECRET`
CRON_SECRET=
